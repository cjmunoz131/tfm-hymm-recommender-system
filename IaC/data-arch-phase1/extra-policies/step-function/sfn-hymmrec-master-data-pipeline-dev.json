[
    {
      "Effect": "Allow",
      "Action": "lambda:InvokeFunction",
      "Resource": [
        "${registerMasterOrchestrationARN}",
        "${updateMasterOrchStatusARN}"
      ]
    },
    {
      "Sid": "AllowGlueJobExecution",
      "Effect": "Allow",
      "Action": [
        "glue:StartJobRun",
        "glue:GetJobRun",
        "glue:GetJobRuns",
        "glue:BatchGetJobs"
      ],
      "Resource": ["${create_obt_silver_job_ARN}","${tmdb_baseline_bronze_job_ARN}","${tmdb_posters_silver_job_ARN}"]
    },
    {
      "Sid": "AllowGlueCrawlerExecution",
      "Effect": "Allow",
      "Action": [
        "glue:StartCrawler",
        "glue:GetCrawler"
      ],
      "Resource": "arn:aws:glue:${region}:*:crawler/${prefix}"
    },
    {
      "Sid": "AllowEventBridgeGlueJobNotification",
      "Effect": "Allow",
      "Action": [
        "events:PutTargets",
        "events:PutRule",
        "events:DescribeRule"
      ],
      "Resource": "arn:aws:events:${region}:${account_id}:rule/StepFunctionsGetEventsForGlueJobsRule"
    },
    {
      "Effect": "Allow",
      "Action": [
        "events:*"
      ],
      "Resource": "*"
    },
    {
      "Effect": "Allow",
      "Action": [
        "xray:PutTraceSegments",
        "xray:PutTelemetryRecords",
        "xray:GetSamplingRules",
        "xray:GetSamplingTargets"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CloudWatchEventsFullAccess",
      "Effect": "Allow",
      "Action": "events:*",
      "Resource": "*"
    },
    {
      "Sid": "IAMPassRoleForCloudWatchEvents",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::*:role/AWS_Events_Invoke_Targets"
    }
]